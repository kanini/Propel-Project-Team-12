    },
    "shadcn": {
      "args": [
        "shadcn@latest",
        "mcp"
      ],
      "command": "npx",
      "env": {},
      "type": "stdio"
    },
    "figma": {
       "url": "https://mcp.figma.com/mcp",
       "type": "http"
     }
  }
