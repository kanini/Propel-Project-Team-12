{
  "servers": {
    "propel-iq": {
      "type": "http",
      "url": "https://mcp-propel-iq-ctb0gghxbweactfq.eastus-01.azurewebsites.net/mcp"
    },
    "sequential-thinking": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-sequential-thinking@latest"]
    },
    "context7": {
      "type": "http",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "${env:CONTEXT7_API_KEY}"
      }
    },
    "playwright": {
      "args": [
        "@playwright/mcp@latest"
      ],
